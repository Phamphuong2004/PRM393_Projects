# Local development (cp .env.example .env)

AI_SERVICE_PORT=8000
# CORS_ORIGINS="https://prm393-projects-journal-tracking.up.railway.app,http://localhost:5001,http://localhost:3000"

# Required for AI Chatbot
MONGODB_URI="mongodb+srv://username:password@cluster.mongodb.net/database_name"
GEMINI_API_KEY="your_gemini_api_key_here"

# Optional: override the Gemini model (chat + vision). Defaults to gemini-2.5-flash.
# Do NOT use gemini-3.x here: it needs thought_signature support that the pinned
# langchain-google-genai version lacks (multi-turn tool calls will 400).
# GEMINI_MODEL=gemini-2.5-flash

# Optional
# EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# --- Railway: copy from RAILWAY_VARIABLES.env hoặc config/railway.mau.env ---
